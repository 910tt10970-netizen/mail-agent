# Скопируйте в файл .env в этом каталоге и подставьте свои значения.
OPENAI_API_KEY=your_api_key_here
# Или единое имя ключа (используется, если OPENAI_API_KEY не задан):
# API_KEY=your_api_key_here

# OpenAI-совместимый прокси (опционально). Пример: https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://your-proxy.example/v1
# Альтернативное имя:
# OPENAI_API_BASE=https://your-proxy.example/v1

# Модель на стороне прокси (опционально). Если не задано — в коде gpt-4o-mini.
# OPENAI_MODEL=provider/model-name
# LLM_MODEL=provider/model-name
